---
import { Icon } from 'astro-icon/components';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote = '' } = Astro.props;
---

<footer class="relative border-t border-blue-950 not-prose bg-[#003060] text-white">
  <div
    class="relative max-w-7xl mx-auto px-4 sm:px-6 intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
  >
    <div class="grid grid-cols-12 gap-4 gap-y-8 sm:gap-8 py-10 md:py-14">
      <!-- Columna izquierda con logo -->
      <div class="col-span-12 lg:col-span-4">
        <div class="mb-4">
          <a class="inline-block" href={getHomePermalink()}>
            <img
              src="/images/optymia-logo-footer.png"
              alt="Optymia"
              class="h-16 md:h-18 w-auto"
            />
          </a>
        </div>

        <div class="text-sm text-slate-300 leading-relaxed max-w-md mb-4">
          Soluciones tecnológicas, analítica avanzada y optimización de procesos para mejorar
          la calidad, la trazabilidad y la toma de decisiones en entornos industriales y organizacionales.
        </div>

        <div class="text-sm flex flex-wrap gap-x-2 gap-y-1 text-slate-300">
          {
            secondaryLinks.map(({ text, href }) => (
              <a
                class="text-slate-300 hover:text-cyan-300 hover:underline transition duration-150 ease-in-out"
                href={href}
                set:html={text}
              />
            ))
          }
        </div>
      </div>

      <!-- Columnas de navegación -->
      {
        links.map(({ title, links }) => (
          <div class="col-span-6 md:col-span-3 lg:col-span-2">
            <div class="text-white font-semibold mb-3">{title}</div>
            {links && Array.isArray(links) && links.length > 0 && (
              <ul class="text-sm space-y-2">
                {links.map(({ text, href, ariaLabel }) => (
                  <li>
                    <a
                      class="text-slate-300 hover:text-cyan-300 hover:underline transition duration-150 ease-in-out"
                      href={href}
                      aria-label={ariaLabel}
                    >
                      <Fragment set:html={text} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>

    <div class="md:flex md:items-center md:justify-between py-6 md:py-8 border-t border-blue-900">
      {
        socialLinks?.length ? (
          <ul class="flex mb-4 md:order-1 -ml-2 md:ml-4 md:mb-0">
            {socialLinks.map(({ ariaLabel, href, text, icon }) => (
              <li>
                <a
                  class="text-slate-300 hover:bg-white/10 hover:text-cyan-300 focus:outline-none focus:ring-4 focus:ring-blue-900 rounded-lg text-sm p-2.5 inline-flex items-center transition"
                  aria-label={ariaLabel}
                  href={href}
                >
                  {icon && <Icon name={icon} class="w-5 h-5" />}
                  <Fragment set:html={text} />
                </a>
              </li>
            ))}
          </ul>
        ) : (
          ''
        )
      }

      <div class="text-sm text-slate-400 mr-4">
        <Fragment set:html={footNote} />
      </div>
    </div>
  </div>
</footer>