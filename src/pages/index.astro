---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Optymia | Soluciones tecnológicas y optimización de procesos',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
  actions={[
    {
  variant: 'primary',
  text: 'Solicitar diagnóstico',
  href: '/contacto',
  class: '!bg-[#003060] hover:!bg-[#00264d] !border-[#003060] !text-white',
},
    { text: 'Ver soluciones', href: '#features' },
  ]}
    image={`
<img src="/src/assets/images/hero-image.png" alt="Optymia soluciones tecnológicas" class="mx-auto rounded-md w-full" />
`}
  >
    <Fragment slot="title">
  Soluciones tecnológicas para la 
  <span class="text-blue-800 dark:text-blue-500">optimización de procesos</span>
  y el control de calidad industrial
</Fragment>

    <Fragment slot="subtitle">
      En <span class="font-semibold">Optymia</span> desarrollamos e implementamos soluciones de analítica avanzada,
      automatización, ciencia de datos y software especializado para transformar datos complejos en decisiones rápidas,
      trazables y rentables.
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

<Note 
  title="Optymia" 
  description="Aplica ciencia de datos, analítica avanzada y tecnología aplicada para optimizar procesos industriales y mejorar la toma de decisiones." 
/>

  <!-- Features Widget *************** -->

   <Features
    id="features"
    tagline="Soluciones"
    title="Servicios tecnológicos para optimizar operación, calidad y toma de decisiones"
    subtitle="Optymia integra analítica avanzada, automatización, software y control de calidad para transformar procesos complejos en resultados medibles, trazables y escalables."
    items={[
      {
        title: 'Analítica avanzada e inteligencia artificial',
        description:
          'Desarrollamos modelos predictivos y de clasificación para apoyar decisiones en calidad, eficiencia operacional, mantenimiento y gestión de riesgo.',
        icon: 'tabler:brain',
      },
      {
        title: 'Optimización de procesos',
        description:
          'Reducimos variabilidad, reprocesos, mermas y costos mediante análisis de datos, modelamiento y mejora continua orientada a la operación.',
        icon: 'tabler:activity',
      },
      {
        title: 'Business Intelligence y dashboards',
        description:
          'Diseñamos tableros ejecutivos e indicadores clave para supervisar procesos, controlar desempeño y disponer de información accionable en tiempo real.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Desarrollo e implementación de software',
        description:
          'Creamos plataformas y aplicaciones para captura, gestión, visualización e interpretación de datos, con soporte, mantenimiento y capacitación.',
        icon: 'tabler:device-desktop-code',
      },
      {
        title: 'Calidad, laboratorio y trazabilidad',
        description:
          'Fortalecemos sistemas de calidad, control metrológico y trazabilidad de datos y equipos, con foco en estandarización y control estadístico.',
        icon: 'tabler:flask',
      },
      {
        title: 'Integración tecnológica y automatización',
        description:
          'Integramos datos, automatizamos reportes y conectamos soluciones tecnológicas para mejorar la continuidad operacional y el control de procesos.',
        icon: 'tabler:cpu',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <!-- Content Widget **************** -->

  <!-- Content Widget **************** -->

  <!-- Steps Widget ****************** -->

   <Steps
  title="De los datos operacionales a decisiones trazables y rentables"
  items={[
    {
      title: 'Etapa 1: <span class="font-medium">Diagnóstico y levantamiento</span>',
      description:
        'Analizamos el proceso, las fuentes de datos, los puntos críticos de control y los objetivos operacionales para definir una línea base clara.',
      icon: 'tabler:search',
    },
    {
      title: 'Etapa 2: <span class="font-medium">Diseño y modelamiento</span>',
      description:
        'Diseñamos la solución tecnológica y analítica más adecuada incorporando ciencia de datos, automatización y criterios de trazabilidad.',
      icon: 'tabler:settings-cog',
    },
    {
      title: 'Etapa 3: <span class="font-medium">Implementación e integración</span>',
      description:
        'Desarrollamos dashboards, reportes, modelos predictivos o plataformas para apoyar la operación.',
      icon: 'tabler:cpu',
    },
    {
      title: 'Etapa 4: <span class="font-medium">Seguimiento y optimización continua</span>',
      description:
        'Monitoreamos indicadores y mejoramos continuamente la solución para maximizar resultados.',
      icon: 'tabler:chart-line',
    },
  ]}
  image={{
  src: '~/assets/images/steps-optymia3.png',
  alt: 'Proceso Optymia',
}}
>

  <Fragment slot="bg">
    <div class="absolute inset-0 bg-gray-50 dark:bg-transparent"></div>
  </Fragment>

</Steps>

   <!-- CallToAction Widget *********** -->

<CallToAction
  actions={[
    {
      variant: 'primary',
      text: 'Solicitar diagnóstico tecnológico',
      href: '/contacto',
    },
    {
      text: 'Conocer nuestras soluciones',
      href: '/soluciones',
    },
  ]}
>
  <Fragment slot="title">
    Transforme datos en decisiones operacionales de alto impacto
  </Fragment>

  <Fragment slot="subtitle">
    En Optymia ayudamos a las organizaciones a optimizar procesos, fortalecer el control de calidad e implementar soluciones tecnológicas y analíticas con foco en resultados medibles.
  </Fragment>
</CallToAction>

  <!-- HighlightedPosts Widget ******* -->

<BlogLatestPosts
  title="Conocimiento y tecnología aplicada"
  information="Explora artículos sobre analítica avanzada, optimización de procesos industriales, ciencia de datos y tecnologías aplicadas al control de calidad."
/>

  <!-- FAQs Widget ******************* -->

<FAQs
  id="faqs"
  title="Preguntas frecuentes"
  subtitle="Respondemos algunas de las consultas más habituales sobre nuestros servicios, tecnologías y enfoque de implementación."
  tagline="Consultas frecuentes"
  classes={{ container: 'max-w-6xl' }}
  items={[
    {
      title: '¿Qué tipo de empresas pueden trabajar con Optymia?',
      description:
        'Optymia está orientada a empresas que necesitan optimizar procesos, fortalecer el control de calidad y tomar decisiones basadas en datos. Esto incluye industrias como alimentos, minería, manufactura, laboratorios, forestal y organizaciones con operaciones intensivas en información y trazabilidad.',
    },
    {
      title: '¿Es necesario contar con grandes volúmenes de datos para iniciar un proyecto?',
      description:
        'No necesariamente. En muchos casos es posible comenzar con datos operacionales, registros de laboratorio, reportes históricos o mediciones ya disponibles. A partir de esa base se puede construir una solución escalable y generar mejoras concretas.',
    },
    {
      title: '¿Optymia puede integrarse con sistemas o procesos ya existentes?',
      description:
        'Sí. Una parte importante del trabajo consiste en integrarse con fuentes de datos, procesos y herramientas ya utilizadas por la organización, evitando reemplazos innecesarios y priorizando soluciones compatibles con la operación actual.',
    },
    {
      title: '¿Qué beneficios puede generar un proyecto de analítica avanzada u optimización?',
      description:
        'Dependiendo del caso, los beneficios pueden incluir reducción de variabilidad, disminución de mermas y reprocesos, mejora del control de calidad, mayor trazabilidad, automatización de reportes y mejor capacidad de decisión a nivel operacional y gerencial.',
    },
    {
      title: '¿Optymia desarrolla software a medida?',
      description:
        'Sí. Podemos diseñar e implementar plataformas, dashboards, aplicaciones y herramientas de análisis adaptadas a los requerimientos del cliente, además de brindar soporte, mantenimiento y capacitación cuando el proyecto lo requiere.',
    },
    {
      title: '¿Cómo se inicia un proyecto con Optymia?',
      description:
        'Normalmente comenzamos con un diagnóstico del proceso, los datos disponibles, los objetivos del cliente y las oportunidades de mejora. Desde allí definimos una propuesta técnica que puede incluir analítica, automatización, software, control de calidad o integración tecnológica.',
    },
  ]}
>

  <Fragment slot="bg">
    <div class="absolute inset-0 bg-gray-50 dark:bg-transparent"></div>
  </Fragment>

</FAQs>

  <!-- Stats Widget ****************** -->

<Stats
  stats={[
    { amount: 'Datos', title: 'Convertidos en información útil' },
    { amount: 'Procesos', title: 'Más controlados y medibles' },
    { amount: 'Calidad', title: 'Menor variabilidad operacional' },
    { amount: 'Gestión', title: 'Decisiones más oportunas' },
  ]}
/>

</Layout>
