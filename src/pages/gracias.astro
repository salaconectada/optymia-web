---
import Layout from '~/layouts/PageLayout.astro';
---

<Layout
  title="Gracias"
  description="Mensaje enviado correctamente"
>
  <section class="relative overflow-hidden py-24 sm:py-32">
    
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-slate-50 to-white dark:from-slate-900 dark:to-slate-950"></div>

    <div class="mx-auto max-w-3xl px-6 lg:px-8 text-center">

      <div class="mx-auto mb-8 flex h-20 w-20 items-center justify-center rounded-2xl bg-primary/10">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-10 w-10 text-primary"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M5 13l4 4L19 7"
          />
        </svg>
      </div>

      <h1 class="text-4xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-5xl">
        Mensaje enviado correctamente
      </h1>

      <p class="mt-6 text-lg leading-8 text-slate-600 dark:text-slate-400">
        Gracias por contactar a Optymia. Nuestro equipo revisará tu requerimiento y te responderá a la brevedad.
      </p>

      <div class="mt-10 flex items-center justify-center gap-x-6">

        <a
          href="/"
          class="rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-white shadow-lg hover:opacity-90 transition"
        >
          Volver al inicio
        </a>

        <a
          href="/soluciones"
          class="text-sm font-semibold leading-6 text-slate-900 dark:text-white"
        >
          Ver soluciones →
        </a>

      </div>

    </div>
  </section>
</Layout>